DJANGO_SECRET_KEY=cambiar-por-valor-seguro
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Orígenes CORS para Vite (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Base de datos (elige UNA vía principal) ---
# Railway / Postgres: DATABASE_URL (lo inyecta el plugin; no uses esto en .env local si quieres MySQL).
# DATABASE_URL=postgres://...

# MySQL local (XAMPP): crea la base en phpMyAdmin y activa estas líneas.
# Deja DATABASE_URL vacío o coméntala para que prevalezca MySQL.
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_DATABASE=inventario_clientes
# MYSQL_USER=root
# MYSQL_PASSWORD=

# Si no hay MYSQL_HOST ni DATABASE_URL → SQLite (db.sqlite3 en la carpeta backend).
